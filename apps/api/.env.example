# Configuración del backend VitaRoot
# Copia este archivo a .env y ajusta valores si lo necesitas.

# Puerto en el que escucha el servidor (default: 3001)
PORT=3001

# Entorno: development | production | test
NODE_ENV=development

# Ruta de la base de datos SQLite (relativa a la raíz del monorepo)
DB_PATH=./data/vitaroot.db